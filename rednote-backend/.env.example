# Server Configuration
PORT=3000

# Google Gemini API Key
GOOGLE_API_KEY=your_google_api_key_here

# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# JWT Secret (required, >= 32 chars)
JWT_SECRET=replace-with-a-random-32-plus-character-secret

# JWT Refresh Secret (required, >= 32 chars)
JWT_REFRESH_SECRET=replace-with-a-third-random-32-plus-character-secret

# Session Secret (required, >= 32 chars)
SESSION_SECRET=replace-with-another-random-32-plus-character-secret

# Optional additional allowlisted AI hosts (comma-separated)
# Defaults always include: api.openai.com, generativelanguage.googleapis.com
AI_BASE_URL_ALLOWLIST=

# Database path (SQLite)
DATABASE_PATH=data/rednote.db
